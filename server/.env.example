# ─── Server ───────────────────────────────────────────────────────────────────
PORT=4000
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# ─── Database (Supabase PostgreSQL) ────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:yourpassword@db.yourproject.supabase.co:5432/postgres

# ─── TURN Server ────────────────────────────────────────────────────────────────
# Required for users behind restrictive NATs/firewalls (corporate networks, some
# mobile carriers). Without TURN, calls between such users will fail to connect.
#
# Option A — Free hosted TURN (Xirsys free tier, ~500MB/month):
#   Sign up at https://xirsys.com, create a channel, copy credentials below.
#
# Option B — Self-hosted coturn (see /turn/README.md for setup):
TURN_URL=turn:your-turn-server.com:3478
TURN_USERNAME=your_turn_username
TURN_CREDENTIAL=your_turn_credential

# ─── File Encryption ────────────────────────────────────────────────────────────
# Used to derive AES-256-GCM keys for encrypting uploaded files at rest.
# MUST be at least 32 characters. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# CRITICAL: If you lose this key, all uploaded files become permanently unreadable.
# Back it up securely (password manager / secrets vault) — never commit to git.
FILE_ENCRYPTION_KEY=change_this_to_a_random_64_character_hex_string_minimum_32_chars